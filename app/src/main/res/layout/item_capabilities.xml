<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:strokeWidth="1dp"
    app:strokeColor="#333333"
    app:cardBackgroundColor="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAPABILITIES"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#AAAAAA" />

        <TextView
            android:id="@+id/wifiEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="WiFi Enabled: --"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/wifiState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WiFi State: --"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/hasInternet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Internet: --"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/metered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Metered: --"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/wifiStandard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WiFi Standard: --"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>