<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===================== HEADER ===================== -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WiFi Diagnostics"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live network telemetry &amp; signal intelligence"
            android:textSize="13sp"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- ===================== SIGNAL CARD ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#333333"
            app:cardBackgroundColor="@color/background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIGNAL"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#000000"/>

                <!-- RSSI -->
                <TextView
                    android:id="@+id/rssi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RSSI: -- dBm"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <!-- Signal level (0–5 bars) -->
                <TextView
                    android:id="@+id/signalLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Signal Level: -- / 5"
                    android:textColor="#FFFFFF"/>

                <!-- Signal quality percentage -->
                <TextView
                    android:id="@+id/signalQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Signal Quality: --%"
                    android:textColor="#FFFFFF"/>

                <!-- Link speed -->
                <TextView
                    android:id="@+id/linkSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Link Speed: -- Mbps"
                    android:textColor="#FFFFFF"/>

                <!-- TX speed (API 29+) -->
                <TextView
                    android:id="@+id/txLinkSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TX Speed: -- Mbps"
                    android:textColor="#FFFFFF"/>

                <!-- RX speed (API 29+) -->
                <TextView
                    android:id="@+id/rxLinkSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RX Speed: -- Mbps"
                    android:textColor="#FFFFFF"/>

                <!-- Frequency -->
                <TextView
                    android:id="@+id/frequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Frequency: -- MHz"
                    android:textColor="#FFFFFF"/>

                <!-- Derived channel -->
                <TextView
                    android:id="@+id/channel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Channel: --"
                    android:textColor="#FFFFFF"/>

                <!-- Band label -->
                <TextView
                    android:id="@+id/band"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Band: --"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== NETWORK CARD ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#333333"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NETWORK"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"/>

                <TextView
                    android:id="@+id/ssid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SSID: --"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/bssid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BSSID: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IP: --"
                    android:textColor="#FFFFFF"/>

                <!-- MAC address (randomised on API 29+) -->
                <TextView
                    android:id="@+id/macAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAC: --"
                    android:textColor="#FFFFFF"/>

                <!-- WifiConfiguration network ID -->
                <TextView
                    android:id="@+id/networkId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Network ID: --"
                    android:textColor="#FFFFFF"/>

                <!-- Hidden SSID flag (API 30+) -->
                <TextView
                    android:id="@+id/hidden"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hidden SSID: --"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== DHCP CARD ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#333333"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DHCP"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"/>

                <TextView
                    android:id="@+id/gateway"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gateway: --"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/subnet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subnet Mask: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/dns1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DNS 1: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/dns2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DNS 2: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/dhcpServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DHCP Server: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/leaseDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lease Duration: --"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== CAPABILITIES CARD ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#333333"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAPABILITIES"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"/>

                <TextView
                    android:id="@+id/wifiEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WiFi Enabled: --"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/wifiState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WiFi State: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/hasInternet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Internet: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/metered"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Metered: --"
                    android:textColor="#FFFFFF"/>

                <!-- WiFi 4/5/6 standard (API 30+) -->
                <TextView
                    android:id="@+id/wifiStandard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WiFi Standard: --"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== STABILITY CARD ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#333333"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STABILITY"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"/>

                <TextView
                    android:id="@+id/avgRssi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avg RSSI: --"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/minRssi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Min RSSI: --"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/maxRssi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max RSSI: --"
                    android:textColor="#FFFFFF"/>

                <!-- Peak-to-peak variation -->
                <TextView
                    android:id="@+id/jitter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jitter: --"
                    android:textColor="#FFFFFF"/>

                <!-- Standard deviation of RSSI window -->
                <TextView
                    android:id="@+id/stdDev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Std Dev: --"
                    android:textColor="#FFFFFF"/>

                <!-- How many samples collected so far -->
                <TextView
                    android:id="@+id/sampleCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Samples: -- / 10"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/stabilityScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stability Score: -- / 100"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===================== INSIGHTS CARD ===================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:strokeWidth="1dp"
            app:strokeColor="#333333"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INSIGHTS"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"/>

                <TextView
                    android:id="@+id/recommendation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyzing..."
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/placementHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Placement: --"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <!-- Extra context sentence -->
                <TextView
                    android:id="@+id/rangeNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>